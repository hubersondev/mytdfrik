# Variables d'environnement pour Docker Compose dev local.
# Copier en `.env` à côté de docker-compose.yml et ajuster.

# PostgreSQL
POSTGRES_USER=mytdfrik
POSTGRES_PASSWORD=changeme
POSTGRES_DB=mytdfrik

# Ports hôte — à modifier si vous avez déjà un Postgres / Redis sur ces ports.
# Le service api dans Docker accède toujours aux services via le réseau interne
# (postgres:5432, redis:6379), ces variables n'affectent que l'exposition externe.
# POSTGRES_HOST_PORT=5432
# REDIS_HOST_PORT=6380
