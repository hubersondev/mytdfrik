# ========== Environnement applicatif ==========
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug
CORS_ORIGINS=http://localhost:3001

# ========== Persistance (obligatoire depuis S1) ==========
DATABASE_URL=postgresql://mytdfrik:changeme@localhost:5432/mytdfrik
REDIS_URL=redis://localhost:6379

# ========== JWT (CDC §9.3, §10.2.3) ==========
# Générer un secret aléatoire fort, par exemple :
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-me-with-a-strong-random-secret-of-at-least-32-chars
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800

# ========== Politique de verrouillage (CDC §10.2.2) ==========
AUTH_MAX_FAILED_LOGINS=5
AUTH_LOCK_DURATION_SECONDS=900
AUTH_LOCK_WINDOW_SECONDS=900

# ========== Validité des jetons de réinitialisation / activation ==========
PASSWORD_RESET_TTL_SECONDS=1800
ACCOUNT_ACTIVATION_TTL_SECONDS=259200

# ========== Hash bcrypt (CDC §10.2.1) ==========
BCRYPT_COST=12

# ========== Sentry (optionnel en dev) ==========
# SENTRY_DSN=

# ========== Pièces jointes & stockage (CDC §3.8, §11.4) ==========
# URL publique de l'API (liens de téléchargement signés des pièces jointes)
API_PUBLIC_BASE_URL=http://localhost:3000
# Driver de stockage : local (dev, disque) ou s3 (staging/prod)
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=.storage
# Scaleway Object Storage (driver s3, à renseigner en staging/prod)
# S3_BUCKET=
# S3_REGION=fr-par
# S3_ENDPOINT=https://s3.fr-par.scw.cloud
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
ATTACHMENT_MAX_FILE_BYTES=26214400
ATTACHMENT_MAX_REQUEST_BYTES=104857600
ATTACHMENT_DOWNLOAD_TTL_SECONDS=300
# Délai du scan antivirus simulé en dev (ClamAV indisponible localement)
ANTIVIRUS_SIMULATED_DELAY_MS=1500

# ========== Email transactionnel ==========
# Priorité du transport : SMTP (si SMTP_HOST défini) > Resend > DEV (log only).
#
# -- Test en local avec Mailpit (recommandé) --
# Lance `docker compose up -d mailpit`, décommente ces 2 lignes, et consulte
# les mails capturés sur http://localhost:8025 (aucun envoi réel).
# SMTP_HOST=localhost
# SMTP_PORT=1025
#
# -- Prod / staging avec Resend --
# Clé sur https://resend.com (API Keys). MAIL_FROM_ADDRESS doit appartenir à un
# domaine vérifié dans Resend (onboarding@resend.dev ne livre qu'au compte Resend).
RESEND_API_KEY=
MAIL_FROM_ADDRESS=onboarding@resend.dev
MAIL_FROM_NAME=MyTDFRIK · TECHDIFRIK

# ========== Bootstrap du premier admin (utilisé par les seeds) ==========
ADMIN_BOOTSTRAP_EMAIL=admin@techdifrik.com
ADMIN_BOOTSTRAP_PASSWORD=ChangeMeImmediately!42
ADMIN_BOOTSTRAP_FIRST_NAME=Admin
ADMIN_BOOTSTRAP_LAST_NAME=Bootstrap
