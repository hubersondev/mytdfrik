# ========== Environnement applicatif ==========
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug
CORS_ORIGINS=http://localhost:3001

# ========== Persistance (obligatoire depuis S1) ==========
DATABASE_URL=postgresql://mytdfrik:changeme@localhost:5432/mytdfrik
REDIS_URL=redis://localhost:6379

# ========== JWT (CDC §9.3, §10.2.3) ==========
# Générer un secret aléatoire fort, par exemple :
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-me-with-a-strong-random-secret-of-at-least-32-chars
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800

# ========== Politique de verrouillage (CDC §10.2.2) ==========
AUTH_MAX_FAILED_LOGINS=5
AUTH_LOCK_DURATION_SECONDS=900
AUTH_LOCK_WINDOW_SECONDS=900

# ========== Validité des jetons de réinitialisation / activation ==========
PASSWORD_RESET_TTL_SECONDS=1800
ACCOUNT_ACTIVATION_TTL_SECONDS=259200

# ========== Hash bcrypt (CDC §10.2.1) ==========
BCRYPT_COST=12

# ========== Sentry (optionnel en dev) ==========
# SENTRY_DSN=

# ========== Bootstrap du premier admin (utilisé par les seeds) ==========
ADMIN_BOOTSTRAP_EMAIL=admin@techdifrik.com
ADMIN_BOOTSTRAP_PASSWORD=ChangeMeImmediately!42
ADMIN_BOOTSTRAP_FIRST_NAME=Admin
ADMIN_BOOTSTRAP_LAST_NAME=Bootstrap
